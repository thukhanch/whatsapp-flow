# Variáveis de ambiente - WhatsApp Flow + Salgaderia Bot
# Copie este arquivo para .env e preencha os valores

# ─── BANCO DE DADOS ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=whatsapp_flow

# ─── EVOLUTION API (WhatsApp) ─────────────────────────────────────
# URL da sua Evolution API instalada na VPS
EVOLUTION_API_URL=https://sua-evolution-api.cloudfy.space
# Chave de API (configurada no painel da Evolution)
EVOLUTION_API_KEY=sua-chave-aqui
# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=salgaderia

# ─── GOOGLE AGENDA ────────────────────────────────────────────────
# ID do calendário Google (aparece nas configurações do Google Agenda)
# Ex: abc123@group.calendar.google.com ou seu@gmail.com
GOOGLE_CALENDAR_ID=seu-calendario@gmail.com
# JSON completo da Service Account do Google Cloud (em uma linha só)
# Veja docs/setup.md para instruções de como criar
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ─── OPENROUTER (IA - opcional, para versão futura) ───────────────
OPENROUTER_API_KEY=sua-chave-openrouter
OPENROUTER_MODEL=google/gemma-3-27b-it:free
